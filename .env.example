# ================================================================
# FreelanceOS Environment Configuration
# ================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your values (NEVER commit it!)
# 3. Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 4. Set environment specific values below
#
# ⚠️ SECURITY RULES:
# - NEVER commit .env file
# - NEVER share .env file
# - NEVER use same SECRET_KEY across environments
# - NEVER hardcode passwords in code
# - Use environment variables for ALL sensitive data
#
# ================================================================
# DJANGO CONFIGURATION
# ================================================================

# SECRET KEY - Generate a new one for each environment!
# Development: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Production: Generate NEW key, store in secure secret manager
SECRET_KEY=change-me-to-a-real-secret-key

# Debug Mode
# WARNING: Set to False in production! Exposes stack traces and config
DEBUG=True

# Allowed Hosts - Comma separated list of domains
# Development: localhost,127.0.0.1
# Production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ================================================================
# DATABASE CONFIGURATION
# ================================================================

DB_ENGINE=django.db.backends.postgresql

# Database name
DB_NAME=freelanceos

# Database user (create with: CREATE USER freelanceos_admin WITH PASSWORD 'password';)
DB_USER=freelanceos_admin

# Database password - Use strong password in production!
# Min 16 chars, mix: uppercase, lowercase, numbers, special chars
DB_PASSWORD=change-me-to-strong-password

# Database host
# Development: localhost
# Production: your-db-host.example.com
DB_HOST=localhost

# Database port
DB_PORT=5432

# ================================================================
# CORS CONFIGURATION
# ================================================================

# Frontend Origins - Comma separated list of allowed origins
# Development: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ================================================================
# JWT TOKEN CONFIGURATION (Optional - Overrides defaults)
# ================================================================

# Token lifetime in minutes (default: 60)
# ACCESS_TOKEN_LIFETIME_MINUTES=60

# Refresh token lifetime in days (default: 7)
# REFRESH_TOKEN_LIFETIME_DAYS=7

# ================================================================
# PRODUCTION SETTINGS (Only needed when DEBUG=False)
# ================================================================

# Hosting provider usually handles these, but you can override:
# Set to False for local development
# Set to True for HTTPS in production
# SECURE_SSL_REDIRECT=True

# Session & CSRF cookies secure flag
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# HSTS (HTTP Strict Transport Security) - seconds
# SECURE_HSTS_SECONDS=31536000

# ================================================================
# OPTIONAL: CACHE CONFIGURATION
# ================================================================

# Cache backend (default: locmem for development)
# CACHE_LOCATION=redis://localhost:6379/1

# ================================================================
# OPTIONAL: EMAIL CONFIGURATION
# ================================================================

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password

# ================================================================
# NOTES
# ================================================================

# - This is an example file. Your actual .env should never be committed.
# - .gitignore includes .env, so it won't be accidentally committed.
# - For production deployment, use your hosting provider's secret management.
# - GitHub Actions: Store secrets in "Settings > Secrets and variables > Actions"
# - Heroku: Use "heroku config:set KEY=value"
# - Docker: Pass -e KEY=value or use --env-file .env
# - Self-hosted: Use systemd environment files or docker compose env
